        async function loadUserBookings() {
            try {
                const res = await fetch('/api/user/bookings');
                const bookings = await res.json();

                const listDiv = document.getElementById("bookingsList");

                if (bookings.length === 0) {
                    listDiv.innerHTML = '<div class="empty-state" style="text-align:center;padding:60px 20px;color:var(--text-muted);"><div style="font-size:48px;margin-bottom:16px;opacity:0.4;">📭</div><h3 style="font-size:18px;color:var(--white);margin-bottom:8px;">No bookings yet</h3><p style="font-size:14px;">Book a service to see your bookings here.</p></div>';
                    return;
                }

                listDiv.innerHTML = bookings.map(b => `
                    <div class="request-row" style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px;margin-bottom:16px;">
                        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:16px;flex-wrap:wrap;">
                            <div style="flex:1;">
                                <strong style="color:var(--white);font-size:16px;">${b.workDescription}</strong>
                                <div style="color:var(--text-muted);font-size:14px;margin-top:8px;">Provider: ${b.provider ? b.provider.name : 'N/A'}</div>
                                <div style="color:var(--text-muted);font-size:14px;">Address: ${b.customerAddress}</div>
                                <div style="color:var(--text-muted);font-size:14px;margin-top:8px;">Status: <span class="status-badge status-${b.status}" style="display:inline-block;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600;background:${b.status === 'completed' ? 'rgba(13,202,240,0.15);color:#0dcaf0' : b.status === 'accepted' ? 'var(--green-dim);color:var(--green)' : 'rgba(255,190,91,0.15);color:#ffbe5b'};">${b.status}</span></div>
                                ${b.status === 'accepted' ? `
                                    <div style="color:var(--green);font-size:13px;margin-top:8px;">OTP: ${b.otp || 'N/A'} (Share this with your provider)</div>
                                ` : ''}
                                ${b.status === 'completed' ? `
                                    <div style="color:#0dcaf0;font-size:13px;margin-top:8px;">✅ Work completed on ${new Date(b.completedAt).toLocaleDateString()}</div>
                                ` : ''}
                            </div>
                            <div>
                                ${b.status === 'accepted' ? `
                                    <button onclick="completeWork('${b._id}')" class="submit-btn" style="width:auto;padding:12px 24px;background:var(--green);color:#000;border:none;border-radius:var(--radius-sm);font-family:'DM Sans',sans-serif;font-size:14px;font-weight:700;cursor:pointer;">Work Done</button>
                                ` : ''}
                            </div>
                        </div>
                    </div>
                `).join('');
            } catch (err) {
                console.error("Error loading bookings:", err);
            }
        }

        // Complete work
        async function completeWork(bookingId) {
            if (!confirm("Mark this work as completed? This will notify your service provider.")) return;

            try {
                const res = await fetch(`/api/bookings/${bookingId}/complete`, {
                    method: "POST"
                });
                const result = await res.json();
                if (res.ok) {
                    alert("Work marked as completed! Your service provider has been notified.");
                    loadUserBookings();
                } else {
                    alert(result.msg || "Failed to complete work");
                }
            } catch (err) {
                alert("Server error");
            }
        }

        // Load bookings on page load
        // loadUserBookings();
    </script>
</body>
</html>