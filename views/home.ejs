            .nav-btns { margin-left: auto; }
            .hamburger { display: block; }

            .hero { padding: 64px 20px 56px; }
            .hero h1 { letter-spacing: -1px; }

            .search-bar {
                flex-direction: column;
                border-radius: 14px;
            }
            .search-bar select {
