    <script>
        // Categories data for autocomplete (from server)
        const allCategories = <%- JSON.stringify(categories) %>;

        function showSuggestions() {
            const input = document.getElementById("searchInput");
            const query = input.value.trim().toLowerCase();
            const dropdown = document.getElementById("searchSuggestions");

            // Visual debug: change border color
            input.style.borderColor = '#00C46A';

            if (!query) {
                dropdown.style.display = 'none';
                return;
            }

            // Build matches from allCategories
            let matches = [];
            allCategories.forEach(cat => {
                // Check category name
                if (cat.name.toLowerCase().includes(query)) {
                    matches.push({ type: 'category', name: cat.name, icon: cat.icon, category: cat.name });
                }
                // Check services
                (cat.services || []).forEach(svc => {
                    if (svc.toLowerCase().includes(query)) {
                        matches.push({ type: 'service', name: svc, icon: cat.icon, category: cat.name });
                    }
                });
            });

            if (matches.length === 0) {
                dropdown.style.display = 'none';
                return;
            }

            // Show suggestions
            dropdown.innerHTML = matches.slice(0, 8).map((item, idx) =>
                `<div onclick="selectSuggestion(this.dataset.category, this.dataset.name)"
                     data-category="${item.category.replace(/"/g, '&quot;')}"
                     data-name="${item.name.replace(/"/g, '&quot;')}"
                     style="padding:12px 16px;cursor:pointer;display:flex;align-items:center;gap:10px;
                            border-bottom:1px solid var(--border);transition:background 0.15s;"
                     onmouseover="this.style.background='rgba(0,196,106,0.08)'"
                     onmouseout="this.style.background='transparent'">
                    <span style="font-size:20px;">${item.icon}</span>
                    <div>
                        <div style="color:var(--white);font-size:14px;font-weight:600;">${item.name}</div>
                        <div style="color:var(--text-muted);font-size:12px;">${item.category} ${item.type === 'service' ? '· service' : ''}</div>
                    </div>
                </div>`
            ).join('');

            dropdown.style.display = 'block';
        }

        function hideSuggestionsDelay() {
            setTimeout(() => {
                const dropdown = document.getElementById("searchSuggestions");
                if (dropdown) dropdown.style.display = 'none';
            }, 200);
        }

        function selectSuggestion(category, serviceName) {
            document.getElementById("searchInput").value = serviceName;
            const catSelect = document.getElementById("searchCategory");
            // Set the category dropdown to match
            for (let i = 0; i < catSelect.options.length; i++) {
                if (catSelect.options[i].value === category) {
                    catSelect.selectedIndex = i;
                    break;
                }
            }
            document.getElementById("searchSuggestions").style.display = 'none';
            handleCategoryClick(category);
        }

        function toggleMenu() {
            document.getElementById("navLinks").classList.toggle("active");
        }

        function scrollCat(dir) {
            const strip = document.getElementById("catStrip");
            strip.scrollBy({ left: dir * 300, behavior: "smooth" });
        }

        function handleCategoryClick(category) {
            const overlay = document.getElementById("loadingOverlay");
            overlay.classList.add("active");

            if (!navigator.geolocation) {
                alert("Geolocation is not supported by your browser.");
                overlay.classList.remove("active");
                window.location.href = "/providers?category=" + encodeURIComponent(category);
                return;
            }

            navigator.geolocation.getCurrentPosition(
                function(pos) {
                    overlay.classList.remove("active");
                    const lat = pos.coords.latitude;
                    const lng = pos.coords.longitude;
                    window.location.href = "/providers?category=" + encodeURIComponent(category) + "&lat=" + lat + "&lng=" + lng;
                },
                function(err) {
                    overlay.classList.remove("active");
                    alert("Location access denied. Showing all providers in this category.");
                    window.location.href = "/providers?category=" + encodeURIComponent(category);
                }
            );
        }

        function handleSearch() {
            const cat = document.getElementById("searchCategory").value;
            const query = document.getElementById("searchInput").value.trim();

            if (cat) {
                handleCategoryClick(cat);
            } else if (query) {
                // Try to find a matching category or service
                const match = searchIndex.find(item =>
                    item.name.toLowerCase() === query.toLowerCase() ||
                    item.name.toLowerCase().includes(query.toLowerCase())
                );
                if (match) {
                    handleCategoryClick(match.category);
                } else {
                    alert("Please select a category from the dropdown or use the search suggestions.");
                }
            } else {
                alert("Please select a category or enter a search term.");
            }
        }

        document.addEventListener("click", function(e) {
            const nav = document.getElementById("navLinks");
            const ham = document.querySelector(".hamburger");
            if (!nav.contains(e.target) && !ham.contains(e.target)) {
                nav.classList.remove("active");
            }
        });
    </script>

