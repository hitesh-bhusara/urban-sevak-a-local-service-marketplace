<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Provider Dashboard - URBAN SEVAK</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --green: #00C46A;
            --green-dark: #009952;
            --green-dim: rgba(0, 196, 106, 0.12);
            --green-glow: rgba(0, 196, 106, 0.25);
            --bg: #0A0B0F;
            --bg2: #0F1117;
            --bg3: #14171F;
            --surface: #1A1D27;
            --surface2: #20243200;
            --border: rgba(255,255,255,0.07);
            --border-hover: rgba(0, 196, 106, 0.4);
            --text: #F0F1F5;
            --text-muted: #7B8094;
            --text-dim: #4A4F65;
            --white: #fff;
            --radius: 14px;
            --radius-sm: 8px;
            --shadow: 0 4px 24px rgba(0,0,0,0.4);
            --shadow-green: 0 0 40px rgba(0,196,106,0.15);
        }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
        }

        /* NOISE TEXTURE OVERLAY */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 9999;
            opacity: 0.35;
        }

        /* NAVBAR */
        .navbar {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: rgba(10, 11, 15, 0.85);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
        }

        .nav-inner {
            max-width: 1400px;
            margin: auto;
            padding: 0 40px;
            height: 72px;
            display: flex;
            align-items: center;
            gap: 32px;
        }

        .logo-img { height: 36px; width: auto; display: block; }

        .logo-text {
            font-family: 'Syne', sans-serif;
            font-size: 22px;
            font-weight: 800;
            color: var(--white);
            letter-spacing: -0.5px;
            text-decoration: none;
        }
        .logo-text span { color: var(--green); }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-left: auto;
        }
        .nav-links a {
            text-decoration: none;
            color: var(--text-muted);
            font-size: 14px;
            font-weight: 500;
            padding: 6px 14px;
            border-radius: var(--radius-sm);
            transition: all 0.2s;
            white-space: nowrap;
        }
        .nav-links a:hover { color: var(--white); background: rgba(255,255,255,0.05); }

        .nav-btns { display: flex; align-items: center; gap: 10px; }

        .btn-ghost {
            padding: 8px 18px;
            background: transparent;
            color: var(--text-muted);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 14px;
            font-weight: 500;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            white-space: nowrap;
        }
        .btn-ghost:hover { border-color: rgba(255,255,255,0.2); color: var(--white); }

        .btn-primary {
            padding: 8px 20px;
            background: var(--green);
            color: #000;
            border: none;
            border-radius: var(--radius-sm);
            font-size: 14px;
            font-weight: 700;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
            letter-spacing: 0.01em;
        }
        .btn-primary:hover { background: #00d975; box-shadow: 0 0 20px rgba(0,196,106,0.4); }

        .hamburger {
            display: none;
            font-size: 22px;
            cursor: pointer;
            background: none;
            border: none;
            color: var(--text-muted);
            margin-left: auto;
        }

        /* MAIN */
        .main { max-width: 1400px; margin: auto; padding: 40px 32px 80px; }

        /* WELCOME BANNER */
        .welcome-banner {
            background: linear-gradient(135deg, rgba(0,196,106,0.1), rgba(0,196,106,0.03));
            border: 1px solid rgba(0,196,106,0.2);
            border-radius: var(--radius);
            padding: 48px 40px;
            color: var(--text);
            margin-bottom: 40px;
            position: relative;
            overflow: hidden;
        }

        .welcome-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 400px;
            height: 400px;
            background: rgba(0,196,106,0.05);
            border-radius: 50%;
            pointer-events: none;
        }

        .welcome-banner h1 {
            font-family: 'Syne', sans-serif;
            font-size: 32px;
            font-weight: 800;
            color: var(--white);
            margin-bottom: 8px;
            position: relative;
        }

        .welcome-banner p {
            font-size: 16px;
            color: var(--text-muted);
            position: relative;
        }

        /* STATS GRID */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 40px;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 0 0 1px rgba(0,196,106,0.1);
        }

        .stat-icon { font-size: 28px; margin-bottom: 12px; }

        .stat-card h2 {
            font-family: 'Syne', sans-serif;
            font-size: 32px;
            font-weight: 800;
            color: var(--white);
            margin-bottom: 4px;
        }

        .stat-card p { font-size: 14px; color: var(--text-muted); font-weight: 500; }

        /* SECTION */
        .section-title {
            font-family: 'Syne', sans-serif;
            font-size: 22px;
            font-weight: 700;
            color: var(--white);
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .section-title a {
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            color: var(--green);
            text-decoration: none;
            font-weight: 500;
            margin-left: auto;
        }

        .section-title a:hover { text-decoration: underline; }

        /* REQUESTS TABLE */
        .requests-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            margin-bottom: 40px;
        }

        .requests-header {
            background: var(--bg2);
            border-bottom: 1px solid var(--border);
            padding: 16px 24px;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-dim);
            display: grid;
            grid-template-columns: 2fr 1.5fr 1fr 1fr 0.8fr;
            gap: 16px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .request-row {
            padding: 16px 24px;
            display: grid;
            grid-template-columns: 2fr 1.5fr 1fr 1fr 0.8fr;
            gap: 16px;
            align-items: center;
            border-bottom: 1px solid var(--bg2);
            transition: background 0.15s;
        }

        .request-row:hover { background: rgba(255,255,255,0.02); }
        .request-row:last-child { border-bottom: none; }

        .request-name { font-weight: 600; color: var(--white); }
        .request-service { font-size: 14px; color: var(--text-muted); }

        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-pending { background: rgba(255,190,91,0.15); color: #ffbe5b; }
        .status-accepted { background: var(--green-dim); color: var(--green); }
        .status-completed { background: rgba(13,202,240,0.15); color: #0dcaf0; }

        .btn-small {
            padding: 6px 16px;
            border-radius: 6px;
            border: none;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            font-family: 'DM Sans', sans-serif;
        }

        .btn-accept { background: var(--green); color: #000; }
        .btn-accept:hover { background: #00d975; box-shadow: 0 0 12px rgba(0,196,106,0.3); }

        .btn-reject { background: rgba(231,76,60,0.15); color: #e74c3c; border: 1px solid rgba(231,76,60,0.3); }
        .btn-reject:hover { background: rgba(231,76,60,0.25); }

        .btn-view {
            background: var(--bg2);
            color: var(--text);
            border: 1px solid var(--border);
        }

        .btn-view:hover { background: var(--bg3); }

        /* REVIEWS */

        /* EMPTY STATE */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-muted);
        }

        .empty-state-icon { font-size: 48px; margin-bottom: 16px; opacity: 0.4; }
        .empty-state h3 { font-size: 18px; color: var(--white); margin-bottom: 8px; }
        .empty-state p { font-size: 14px; }

        /* PROFILE CARD */
        .profile-section { display: grid; grid-template-columns: 300px 1fr; gap: 24px; margin-bottom: 40px; }

        .profile-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
        }

        .profile-header {
            background: linear-gradient(135deg, rgba(0,196,106,0.15), rgba(0,196,106,0.05));
            padding: 32px 24px;
            text-align: center;
            border-bottom: 1px solid var(--border);
        }

        .profile-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            margin: 0 auto 12px;
            border: 2px solid rgba(0,196,106,0.3);
        }

        .profile-name { font-size: 18px; font-weight: 700; color: var(--white); }
        .profile-category { font-size: 14px; color: var(--text-muted); margin-top: 4px; }

        .profile-body { padding: 20px 24px; }

        .profile-detail {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 10px;
        }

        .profile-detail-icon { font-size: 16px; width: 20px; text-align: center; }

        /* QUICK ACTIONS */
        .actions-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }

        .action-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px;
            cursor: pointer;
            transition: all 0.2s;
            text-align: center;
        }

        .action-card:hover {
            border-color: var(--border-hover);
            transform: translateY(-2px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 0 0 1px rgba(0,196,106,0.1);
        }

        .action-icon { font-size: 28px; margin-bottom: 12px; }

        .action-card h3 {
            font-family: 'Syne', sans-serif;
            font-size: 16px;
            font-weight: 700;
            color: var(--white);
            margin-bottom: 4px;
        }

        .action-card p { font-size: 13px; color: var(--text-muted); }

        /* RESPONSIVE */
        @media (max-width: 1200px) {
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
            .profile-section { grid-template-columns: 1fr; }
        }

        @media (max-width: 768px) {
            .nav-inner { padding: 0 20px; height: 64px; gap: 12px; }

            .nav-links {
                position: fixed;
                top: 64px; left: 0; right: 0;
                background: rgba(10,11,15,0.98);
                backdrop-filter: blur(20px);
                flex-direction: column;
                padding: 20px;
                gap: 8px;
                border-bottom: 1px solid var(--border);
                display: none;
                z-index: 999;
            }

            .nav-links.active { display: flex; }
            .nav-links a { padding: 10px 16px; border-radius: var(--radius-sm); }
            .nav-btns { margin-left: auto; }
            .hamburger { display: block; }

            .main { padding: 24px 16px 60px; }

            .welcome-banner { padding: 32px 24px; }
            .welcome-banner h1 { font-size: 24px; }

            .stats-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
            .stat-card { padding: 16px; }
            .stat-card h2 { font-size: 24px; }

            .requests-header, .request-row { grid-template-columns: 1fr; gap: 8px; }
            .actions-grid { grid-template-columns: 1fr; }
        }

        @media (max-width: 480px) {
            .stats-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="nav-inner">
            <a href="/">
                <img src="/assets/logo.png" alt="URBAN SEVAK" class="logo-img" onerror="this.style.display='none';this.nextElementSibling.style.display='block'">
                <span class="logo-text" style="display:none">URBAN<span>SEVAK</span></span>
            </a>
            <div class="nav-links" id="navLinks">
                <a href="/">Home</a>
                <a href="/login">Log In</a>
                <a href="/signupas">Sign Up</a>
            </div>
            <div class="nav-btns">
                <a href="/sprovidersignup" class="btn-ghost">Become a Provider</a>
            </div>
            <button class="hamburger" onclick="toggleMenu()">&#9776;</button>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <div class="main">

        <!-- Welcome Banner -->
        <div class="welcome-banner">
            <h1>Welcome, <%= provider.name %>! 🎉</h1>
            <p>Your account is ready. Start receiving service requests from customers.</p>
        </div>

        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">📋</div>
                <h2><%= pendingCount || 0 %></h2>
                <p>Pending Requests</p>
            </div>
            <div class="stat-card">
                <div class="stat-icon">✅</div>
                <h2><%= completedCount || 0 %></h2>
                <p>Completed Jobs</p>
            </div>
            <div class="stat-card">
                <div class="stat-icon">⭐</div>
                <h2><%= provider.rating || 0 %> <span style="font-size:14px;color:var(--text-muted);">(<%= provider.totalReviews || 0 %>)</span></h2>
                <p>Rating</p>
            </div>
            <div class="stat-card">
                <div class="stat-icon">👁️</div>
                <h2><%= acceptedCount || 0 %></h2>
                <p>Active Jobs</p>
            </div>
        </div>

        <!-- Profile Section -->
        <div class="profile-section">
            <div class="profile-card">
                <div class="profile-header">
                    <% if (provider.profileImage) { %>
                        <img src="<%= provider.profileImage && provider.profileImage.startsWith('http') ? provider.profileImage : '/uploads/' + provider.profileImage %>" alt="<%= provider.name %>" style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:2px solid rgba(0,196,106,0.3);margin:0 auto 12px;">
                    <% } else { %>
                        <div class="profile-avatar">👤</div>
                    <% } %>
                    <div class="profile-name"><%= provider.name %></div>
                    <div class="profile-category"><%= provider.category || 'Not set' %></div>
                </div>
                <div class="profile-body">
                    <div class="profile-detail">
                        <span class="profile-detail-icon">📞</span>
                        <span><%= provider.phone %></span>
                    </div>
                    <div class="profile-detail">
                        <span class="profile-detail-icon">📍</span>
                        <span><%= provider.address %></span>
                    </div>
                    <div class="profile-detail">
                        <span class="profile-detail-icon">🛠️</span>
                        <span><%= (provider.services || []).join(', ') %></span>
                    </div>
                    <div class="profile-detail">
                        <span class="profile-detail-icon">🧾</span>
                        <span><%= provider.experience || 0 %> year(s) experience</span>
                    </div>
                    <button class="btn-ghost" style="width:100%;margin-top:16px;cursor:pointer;">Edit Profile</button>
                </div>
            </div>

            <!-- Quick Actions -->
            <div>
                <h2 class="section-title">Quick Actions</h2>
                <div class="actions-grid">
                    <div class="action-card">
                        <div class="action-icon">📋</div>
                        <h3>View Requests</h3>
                        <p>See all incoming service requests</p>
                    </div>
                    <div class="action-card">
                        <div class="action-icon">🛠️</div>
                        <h3>Update Services</h3>
                        <p>Add or modify your service offerings</p>
                    </div>
                    <div class="action-card">
                        <div class="action-icon">⚙️</div>
                        <h3>Account Settings</h3>
                        <p>Manage password, notifications & more</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Requests -->
        <h2 class="section-title">Recent Requests <a href="#">View All</a></h2>
        <div class="requests-card" id="requestsCard">
            <!-- Table Header -->
            <div class="requests-header">
                <span>Customer</span>
                <span>Work</span>
                <span>Date</span>
                <span>Status</span>
                <span>Action</span>
            </div>
            <!-- Dynamic Content -->
            <div id="requestsList"></div>
            <!-- Empty State -->
            <div class="empty-state" id="emptyState">
                <div class="empty-state-icon">📭</div>
                <h3>No requests yet</h3>
                <p>When customers book your services, they'll appear here.</p>
            </div>
        </div>

        <!-- Reviews Section -->
        <h2 class="section-title" style="margin-top:40px;">Customer Reviews</h2>
        <div id="reviewsCard" style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:24px;">
            <div id="reviewsList"><div style="color:var(--text-muted);text-align:center;padding:20px 0;">Loading reviews...</div></div>
            <div class="empty-state" id="reviewsEmptyState" style="display:none;">
                <div class="empty-state-icon">📭</div>
                <h3>No reviews yet</h3>
                <p>Your reviews will appear here after customers rate your services.</p>
            </div>
        </div>

        <!-- Logout -->
        <div style="text-align:center;padding:20px 0 40px;">
            <button class="btn-ghost" style="cursor:pointer;" onclick="location.href='/'">Logout</button>
        </div>

    </div>

    <script>
        function toggleMenu() {
            document.getElementById("navLinks").classList.toggle("active");
        }

        document.addEventListener("click", function(e) {
            const nav = document.getElementById("navLinks");
            const ham = document.querySelector(".hamburger");
            if (!nav.contains(e.target) && !ham.contains(e.target)) {
                nav.classList.remove("active");
            }
        });

        // Load bookings when page loads
        async function loadBookings() {
            try {
                const res = await fetch(`/api/bookings/<%= provider._id %>`);
                const bookings = await res.json();

                const requestsList = document.getElementById("requestsList");
                const emptyState = document.getElementById("emptyState");

                if (bookings.length === 0) {
                    emptyState.style.display = "block";
                    return;
                }

                emptyState.style.display = "none";

                requestsList.innerHTML = bookings.map(b => `
                    <div class="request-row">
                        <span class="request-name">${b.customerName}</span>
                        <span class="request-service">${b.workDescription}</span>
                        <span style="font-size:14px;color:var(--text-muted);">${new Date(b.createdAt).toLocaleDateString()}</span>
                        <span><span class="status-badge status-${b.status}">${b.status}</span></span>
                        <span>
                            ${b.status === 'pending' ? `
                                <button class="btn-small btn-accept" onclick="handleAccept('${b._id}')">Accept</button>
                                <button class="btn-small btn-reject" onclick="handleReject('${b._id}')">Reject</button>
                            ` : b.status === 'accepted' ? `
                                <span style="color:var(--green);font-size:13px;">OTP: ${b.otp || 'N/A'}</span>
                            ` : ''}
                        </span>
                    </div>
                `).join('');
            } catch (err) {
                console.error("Error loading bookings:", err);
            }
        }

        // Handle Accept
        async function handleAccept(bookingId) {
            if (!confirm("Accept this booking request?")) return;

            try {
                const res = await fetch(`/api/bookings/${bookingId}/accept`, {
                    method: "POST"
                });
                const result = await res.json();
                if (res.ok) {
                    alert("Booking accepted! OTP: " + result.otp);
                    loadBookings();
                } else {
                    alert(result.msg || "Failed to accept booking");
                }
            } catch (err) {
                alert("Server error");
            }
        }

        // Handle Reject
        async function handleReject(bookingId) {
            if (!confirm("Reject this booking request?")) return;

            try {
                const res = await fetch(`/api/bookings/${bookingId}/reject`, {
                    method: "POST"
                });
                const result = await res.json();
                if (res.ok) {
                    alert("Booking rejected.");
                    loadBookings();
                } else {
                    alert(result.msg || "Failed to reject booking");
                }
            } catch (err) {
                alert("Server error");
            }
        }

        // Load bookings on page load
        loadBookings();

        // Load reviews on page load
        async function loadReviews() {
            try {
                const res = await fetch(`/api/provider/<%= provider._id %>/reviews`);
                const reviews = await res.json();

                const reviewsList = document.getElementById("reviewsList");
                const emptyState = document.getElementById("reviewsEmptyState");

                if (reviews.length === 0) {
                    reviewsList.style.display = "none";
                    emptyState.style.display = "block";
                    return;
                }

                reviewsList.style.display = "block";
                emptyState.style.display = "none";

                reviewsList.innerHTML = reviews.map(r => `
                    <div style="padding:16px 0;border-bottom:1px solid var(--border);last-child:border:0;">
                        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                            <div style="width:36px;height:36px;border-radius:50%;background:rgba(0,196,106,0.2);display:flex;align-items:center;justify-content:center;font-weight:600;color:var(--green);">
                                ${r.customer && r.customer.name ? r.customer.name.charAt(0).toUpperCase() : '?'}
                            </div>
                            <div>
                                <div style="font-weight:600;color:var(--white);">${r.customer && r.customer.name ? r.customer.name : 'Anonymous'}</div>
                                <div style="color:#FFD700;font-size:14px;">${'★'.repeat(r.rating)}${'☆'.repeat(5 - r.rating)}</div>
                            </div>
                            <div style="margin-left:auto;font-size:12px;color:var(--text-dim);">${new Date(r.createdAt).toLocaleDateString()}</div>
                        </div>
                        ${r.review ? `<div style="color:var(--text-muted);font-size:14px;padding-left:46px;">${r.review}</div>` : ''}
                    </div>
                `).join('');
            } catch (err) {
                console.error("Error loading reviews:", err);
                document.getElementById("reviewsList").innerHTML = '<div style="color:var(--text-muted);text-align:center;padding:20px 0;">Failed to load reviews</div>';
            }
        }

        loadReviews();
    </script>
</body>
</html>
