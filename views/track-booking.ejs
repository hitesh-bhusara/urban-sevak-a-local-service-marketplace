<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Track Booking - URBAN SEVAK</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --green: #00C46A;
            --green-dark: #009952;
            --green-dim: rgba(0, 196, 106, 0.12);
            --bg: #0A0B0F;
            --bg2: #0F1117;
            --surface: #1A1D27;
            --border: rgba(255,255,255,0.07);
            --text: #F0F1F5;
            --text-muted: #7B8094;
            --text-dim: #4A4F65;
            --radius: 14px;
            --radius-sm: 8px;
        }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        /* NAVBAR */
        .navbar {
            position: sticky; top: 0; z-index: 1000;
            background: rgba(10, 11, 15, 0.85);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
        }
        .nav-inner {
            max-width: 1400px; margin: auto;
            padding: 0 40px; height: 72px;
            display: flex; align-items: center; gap: 32px;
        }
        .logo-text {
            font-family: 'Syne', sans-serif;
            font-size: 22px; font-weight: 800;
            color: var(--text); text-decoration: none;
        }
        .logo-text span { color: var(--green); }
        .nav-links { display: flex; align-items: center; gap: 8px; margin-left: auto; }
        .nav-links a {
            text-decoration: none; color: var(--text-muted);
            font-size: 14px; font-weight: 500;
            padding: 6px 14px; border-radius: var(--radius-sm);
            transition: all 0.2s;
        }
        .nav-links a:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .btn-ghost {
            padding: 8px 18px; background: transparent;
            color: var(--text-muted); border: 1px solid var(--border);
            border-radius: var(--radius-sm); font-size: 14px;
            font-weight: 500; cursor: pointer; transition: all 0.2s;
            text-decoration: none;
        }
        .btn-ghost:hover { border-color: rgba(255,255,255,0.2); color: var(--text); }

        /* MAIN */
        .main { max-width: 800px; margin: auto; padding: 60px 32px 80px; }

        /* HEADER */
        .page-header { text-align: center; margin-bottom: 40px; }
        .page-header h1 {
            font-family: 'Syne', sans-serif;
            font-size: 32px; font-weight: 800;
            color: var(--white); margin-bottom: 8px;
        }
        .page-header p { color: var(--text-muted); font-size: 15px; }

        /* BOOKING CARD */
        .booking-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 20px; margin-bottom: 16px;
            transition: border-color 0.2s;
        }
        .booking-card:hover { border-color: rgba(255,255,255,0.12); }

        .booking-header {
            display: flex; align-items: center;
            justify-content: space-between; margin-bottom: 12px;
        }
        .booking-provider { font-weight: 600; color: var(--text); }
        .booking-date { font-size: 13px; color: var(--text-dim); }

        .status-badge {
            display: inline-block; padding: 4px 12px;
            border-radius: 20px; font-size: 12px; font-weight: 600;
        }
        .status-pending { background: rgba(255,190,91,0.15); color: #ffbe5b; }
        .status-accepted { background: var(--green-dim); color: var(--green); }
        .status-rejected { background: rgba(231,76,60,0.15); color: #e74c3c; }
        .status-completed { background: rgba(13,202,240,0.15); color: #0dcaf0; }

        .booking-detail {
            font-size: 14px; color: var(--text-muted);
            margin-bottom: 6px;
        }
        .booking-detail strong { color: var(--text); }

        .otp-display {
            background: rgba(0,196,106,0.1);
            border: 1px solid rgba(0,196,106,0.3);
            border-radius: 8px; padding: 12px;
            text-align: center; margin-top: 12px;
        }
        .otp-label { font-size: 12px; color: var(--text-dim); margin-bottom: 4px; }
        .otp-code { font-size: 32px; font-weight: 800; color: var(--green); letter-spacing: 6px; }

        .work-done-btn {
            width: 100%; padding: 12px 24px;
            background: var(--green); color: #000;
            border: none; border-radius: var(--radius-sm);
            font-family: 'DM Sans', sans-serif;
            font-size: 14px; font-weight: 700;
            cursor: pointer; transition: all 0.2s;
            margin-top: 12px;
        }
        .work-done-btn:hover {
            background: #00d975;
            box-shadow: 0 0 20px rgba(0,196,106,0.4);
        }

        .completed-msg {
            color: #0dcaf0; font-size: 13px;
            margin-top: 8px;
        }

        /* EMPTY STATE */
        .empty-state {
            text-align: center; padding: 60px 20px;
            color: var(--text-muted);
        }
        .empty-state-icon { font-size: 48px; margin-bottom: 16px; opacity: 0.4; }
        .empty-state h3 { font-size: 18px; color: var(--white); margin-bottom: 8px; }
        .empty-state p { font-size: 14px; }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            .nav-inner { padding: 0 20px; height: 64px; }
            .main { padding: 30px 16px 60px; }
            .page-header h1 { font-size: 24px; }
        }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="nav-inner">
            <a href="/" class="logo-text">Urban<span>Sevak</span></a>
            <div class="nav-links">
                <a href="/home">Home</a>
                <a href="/logout">Log Out</a>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <div class="main">
        <div class="page-header">
            <h1>Track Your Bookings</h1>
            <p>View all your service bookings and their status</p>
        </div>

        <!-- BOOKING LIST -->
        <% if (bookings.length === 0) { %>
            <div class="empty-state">
                <div class="empty-state-icon">📭</div>
                <h3>No bookings yet</h3>
                <p>When you book a service, it will appear here.</p>
            </div>
        <% } else { %>
            <div id="bookingList">
                <% bookings.forEach(function(b) { %>
                    <div class="booking-card" id="booking-<%= b._id %>">
                        <div class="booking-header">
                            <div>
                                <div class="booking-provider"><%= b.provider ? b.provider.name : 'Provider' %></div>
                                <div class="booking-date"><%= new Date(b.createdAt).toLocaleString() %></div>
                            </div>
                            <span class="status-badge status-<%= b.status %>"><%= b.status %></span>
                        </div>
                        <div class="booking-detail"><strong>Work:</strong> <%= b.workDescription %></div>
                        <div class="booking-detail"><strong>Address:</strong> <%= b.customerAddress %></div>
                        <% if (b.status === 'accepted' && b.otp) { %>
                            <div class="otp-display">
                                <div class="otp-label">Your OTP (Share with Provider)</div>
                                <div class="otp-code"><%= b.otp %></div>
                            </div>
                        <% } %>
                        <% if (b.status === 'accepted') { %>
                            <button class="work-done-btn" onclick="completeWork('<%= b._id %>')">✅ Work Done</button>
                        <% } %>
                        <% if (b.status === 'completed') { %>
                            <div class="completed-msg">✅ Work completed on <%= new Date(b.completedAt).toLocaleDateString() %></div>
                        <% } %>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>

    <script>
        async function completeWork(bookingId) {
            if (!confirm("Mark this work as completed? This will notify your service provider.")) return;

            try {
                const res = await fetch(`/api/bookings/${bookingId}/complete`, {
                    method: "POST"
                });
                const result = await res.json();
                if (res.ok) {
                    alert("Work marked as completed! Your service provider has been notified.");
                    location.reload();
                } else {
                    alert(result.msg || "Failed to complete work");
                }
            } catch (err) {
                alert("Server error");
            }
        }
    </script>
</body>
</html>
